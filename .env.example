# ─────────────────────────────────────────────────────────────────────
# CentProof website environment variables
#
# Copy this to `.env.local` for local development.  In production, set
# these in your hosting provider's environment-variable panel (Vercel /
# Cloudflare Pages / Netlify / Render / etc.).
#
# All values prefixed with NEXT_PUBLIC_ are inlined into the client
# bundle at build time and are therefore safe to share publicly — they
# are URLs, not secrets.
# ─────────────────────────────────────────────────────────────────────

# Canonical site URL.  Used in metadata, sitemap, robots, and OG tags.
# Production should always be the bare apex domain.
NEXT_PUBLIC_SITE_URL="https://centproof.com"

# ─── LemonSqueezy checkout URLs ──────────────────────────────────────
# After creating your two products in the LemonSqueezy dashboard, copy
# the public checkout URL of each variant here.  Format usually:
#   https://centproof.lemonsqueezy.com/buy/<uuid>
# (or your custom store slug).
NEXT_PUBLIC_LEMONSQUEEZY_LIFETIME_URL=""
NEXT_PUBLIC_LEMONSQUEEZY_MONTHLY_URL=""

# Optional: launch coupon code created in LemonSqueezy.  When set, the
# Pro Lifetime CTA appends `?checkout[discount_code]=<code>` so the
# launch promo applies automatically.  Leave blank to disable.
NEXT_PUBLIC_LEMONSQUEEZY_LAUNCH_COUPON="LAUNCH2026"

# ─── Desktop app download ────────────────────────────────────────────
# The /download page reads this URL and points the "Download .dmg"
# button at it.  Recommended: GitHub Releases "latest download" URL,
# which keeps working across releases.
NEXT_PUBLIC_DOWNLOAD_URL=""

# Optional: human-readable label shown beneath the download button,
# e.g. "v1.0.0 — May 2026".
NEXT_PUBLIC_DOWNLOAD_VERSION_LABEL=""

# ─── Bank-request form email delivery (Phase 5.14) ───────────────────
# The /api/bank-request route uses these to send the request to the
# support inbox via SMTP.  These are SECRETS and must be set in your
# hosting provider's env panel only — never commit real values.
#
# Recommended for Java Mantra Corp's existing setup: Hostinger SMTP
# on port 587 with STARTTLS.  Other providers (Resend SMTP, SES, etc.)
# work too — adjust host/port to match.
MAIL_HOST=""
MAIL_PORT="587"
MAIL_USERNAME=""
MAIL_PASSWORD=""
# Where the requests get delivered.  Defaults to MAIL_USERNAME if unset,
# so you only need to set this if you forward to a different mailbox.
SUPPORT_INBOX=""

# ─── Tauri auto-updater manifest ─────────────────────────────────────
# The /updates/[target]/[version] route forwards this manifest to the
# desktop app when an update is available.  This URL should return a
# JSON document signed in CI (the route itself never holds the private
# key).  Recommended: a static JSON asset on your release host or a
# Cloudflare Worker that serves the latest signed manifest.
#
# Leave blank pre-launch — the route returns 204 (no update) and the
# desktop app will quietly do nothing.
NEXT_PUBLIC_LATEST_MANIFEST_URL=""
